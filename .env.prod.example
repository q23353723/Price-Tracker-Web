# PostgreSQL Databse
POSTGRES_USER=pricetracker_prod
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=pricetracker_prod_db

# pgAdmin
PGADMIN_EMAIL=admin@laiyouda.com
PGADMIN_PASSWORD=your_secure_pgadmin_password_here

# Backend FastAPI Settings
# Database URL, must match the PostgreSQL credentials above
DATABASE_URL=postgresql://pricetracker_prod:your_secure_db_password_here@postgres:5432/pricetracker_prod_db

# Security
SECRET_KEY=generate_a_strong_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Third Party Integrations
LINE_CHANNEL_ACCESS_TOKEN=your_line_bot_token
LINE_CHANNEL_SECRET=your_line_bot_secret
OPENAI_API_KEY=your_openai_api_key_if_needed
