# =============================================
# PostgreSQL (Docker)
# =============================================
POSTGRES_USER=pricetracker
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=pricetracker_db

# =============================================
# FastAPI Backend
# =============================================
DATABASE_URL=postgresql://pricetracker:your_password_here@localhost:5432/pricetracker_db
SECRET_KEY=your_secret_key_here

# =============================================
# pgAdmin (選用)
# =============================================
PGADMIN_EMAIL=admin@pricetracker.local
PGADMIN_PASSWORD=your_pgadmin_password_here

# =============================================
# Email 通知 (SMTP)
# =============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[EMAIL_ADDRESS]
SMTP_PASSWORD=your_smtp_password_here

# =============================================
# Line Messaging API
# =============================================
# 至 https://developers.line.biz/ 建立 Messaging API Channel 後取得
# Channel 需設定 Webhook，使用者也需先將 Bot 加為好友
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
